# Copy this file to `.env` and fill in your key(s). `.env` is gitignored, so your
# secrets never get committed. Narwhal auto-loads `.env` from the working directory
# (or a parent) when a key isn't already provided via a flag or environment variable.

# Chrome UX Report (CrUX) API key — enables `narwhal vitals` (real Core Web Vitals,
# field data). Get a free key: https://developer.chrome.com/docs/crux/api
CRUX_API_KEY=

# PageSpeed Insights key — enables `narwhal vitals --lab` (Lighthouse LAB data for
# any URL, incl. low-traffic pages CrUX has no data for). Optional (keyless works at
# a low, shared quota). ONE Google Cloud key can serve both: enable the "Chrome UX
# Report API" and the "PageSpeed Insights API" on the same project, then you can set
# just CRUX_API_KEY. https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
